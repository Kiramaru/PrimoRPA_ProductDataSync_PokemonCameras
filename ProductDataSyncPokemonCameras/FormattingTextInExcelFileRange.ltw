        </ScriptVariable>
        <ScriptVariable>
            <Name>in_rangeForChangingText</Name>
            <Group />
            <Comment>Диапазон для изменения текста</Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_boldTextSelection</Name>
            <Group />
            <Comment>Жирное выделение текста</Comment>
            <DataTypeString>Boolean</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
