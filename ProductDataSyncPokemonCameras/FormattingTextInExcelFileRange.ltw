            <SerializationItem>
                <IsListValue>false</IsListValue>
                <Name>ScriptCode</Name>
                <Value xsi:type="xsd:string">using System;
using System.Collections.Generic;
using System.Text;
using LTools.Scripting.Model;
using LTools.Network.Model;

public class PrimoScript
{
	public static LTools.Scripting.CSharp.ScriptDebugger __debug;
	
	public void main(LTools.Common.Model.WorkflowData wf)
    {
        String str_pathExcelFile = wf.GetArgument("in_pathExcelFile").ToString();
		String str_nameOfSheet = wf.GetArgument("in_nameOfSheet").ToString();
		String str_rangeForChangingText = wf.GetArgument("in_rangeForChangingText").ToString();
		
		Boolean b_boldTextSelection = (Boolean)wf.GetArgument("in_boldTextSelection");
		Boolean b_italicizedTextSelection = (Boolean)wf.GetArgument("in_italicizedTextSelection");
		Boolean b_underliningText = (Boolean)wf.GetArgument("in_underliningText");
		
		Workbook wb_excelFile = new Workbook();//Объявление Excel файла
		wb_excelFile.LoadDocument(str_pathExcelFile);//Подгрузка документа
		Worksheet ws_excelSheet = wb_excelFile.Worksheets[str_nameOfSheet];//Получение листа для считывания диапазона
		
		CellRange cr_rangeForChangingText = ws_excelSheet.Range[str_rangeForChangingText];//Считывание диапазона
		DevExpress.Spreadsheet.Formatting form_formatting = cr_rangeForChangingText.BeginUpdateFormatting();//Начало изменения форматирования
		
		if(b_boldTextSelection) form_formatting.Font.Bold = true; 
		if(b_italicizedTextSelection) form_formatting.Font.Italic = true;
		if(b_underliningText) form_formatting.Font.UnderlineType = UnderlineType.Single;
		
		cr_rangeForChangingText.EndUpdateFormatting(form_formatting);//Завершение изменения форматирования
		wb_excelFile.SaveDocument(str_pathExcelFile);//Сохранение документа
    }
}</Value>
            </SerializationItem>
        </Properties>
        <IsBreakpoint>false</IsBreakpoint>
        <IsIgnore>false</IsIgnore>
        <Components />
    </RootContainer>
    <GlobalVariables />
