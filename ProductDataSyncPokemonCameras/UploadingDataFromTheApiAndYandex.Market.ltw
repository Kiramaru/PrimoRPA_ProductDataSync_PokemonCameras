                                                                <IsListValue>false</IsListValue>
                                                                <Name>Text</Name>
                                                                <Value xsi:type="xsd:string">"let cards = document.querySelectorAll(\"div[data-auto-themename='list_full']\"); let items = []; cards.forEach(card =&gt; { let title = card.querySelector(\"span[role='link']\")?.innerText?.trim() || ''; let priceSpan = card.querySelector(\".ds-valueLine.ds-flex_inl.ds-flex_ai_b.ds-flex_shr_0 span\"); let price = priceSpan?.innerText?.trim() || ''; let currency = priceSpan?.nextSibling?.textContent?.trim() || ''; let rating = card.querySelector(\"div[data-zone-name='rating'] span\")?.innerText?.match(/\\d+(?:\\.\\d+)?/)?.[0] || ''; let specifications = \"\"; let specItems = card.querySelectorAll(\"._1-Mwy &gt; div\"); specItems.forEach(spec =&gt; { let spans = spec.querySelectorAll(\"span\"); if (spans.length &gt;= 2) { specifications += `${spans[0].innerText.trim()}: ${spans[1].innerText.trim()}\\n`; } }); let link = card.querySelector(\"a\")?.href || ''; items.push({ title: title, price: price, currency: currency, rating: rating, specifications: specifications.trim(), link: link }); }); return JSON.stringify({ total: items.length, scrapedAt: new Date().toISOString(), items: items}, null, 2);"</Value>
                                                            </SerializationItem>
                                                            <SerializationItem>
                                                                <IsListValue>false</IsListValue>
