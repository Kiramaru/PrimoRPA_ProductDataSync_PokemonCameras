            <SerializationItem>
                <IsListValue>false</IsListValue>
                <Name>ScriptCode</Name>
                <Value xsi:type="xsd:string">using System;
using System.Collections.Generic;
using System.Text;
using LTools.Scripting.Model;
using LTools.Network.Model;
using System.Drawing;

public class PrimoScript
{
	public static LTools.Scripting.CSharp.ScriptDebugger __debug;
	
	public void main(LTools.Common.Model.WorkflowData wf)
    {
        String str_pathExcelFile = wf.GetArgument("in_pathExcelFile").ToString();
		String str_nameOfSheet = wf.GetArgument("in_nameOfSheet").ToString();
		String str_rangeTables = wf.GetArgument("in_rangeTables").ToString();
		String str_hexBackgroundColor = wf.GetArgument("in_hexBackgroundColor").ToString();
		
		Workbook wb_excelFile = new Workbook();//Объявление Excel файла
		wb_excelFile.LoadDocument(str_pathExcelFile);//Подгрузка документа
		Worksheet ws_excelSheet = wb_excelFile.Worksheets[str_nameOfSheet];//Получение листа для считывания диапазона
		
		CellRange cr_rangeTable = ws_excelSheet.Range[str_rangeTables];//Считывание диапазона
		DevExpress.Spreadsheet.Formatting form_formatting = cr_rangeTable.BeginUpdateFormatting();//Начало изменения форматирования
		
		form_formatting.Fill.BackgroundColor = ColorTranslator.FromHtml(str_hexBackgroundColor);//Цвет фона диапазона
		
		cr_rangeTable.EndUpdateFormatting(form_formatting);//Завершение изменения форматирования
		wb_excelFile.SaveDocument(str_pathExcelFile);//Сохранение документа
    }
}</Value>
            </SerializationItem>
        </Properties>
        <IsBreakpoint>false</IsBreakpoint>
        <IsIgnore>false</IsIgnore>
        <Components />
    </RootContainer>
    <GlobalVariables />
    <Arguments>
        <ScriptVariable>
            <Name>in_pathExcelFile</Name>
            <Group />
            <Comment>Путь к Excel файлу</Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_nameOfSheet</Name>
            <Group />
            <Comment>Название листа</Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_rangeTables</Name>
            <Group />
            <Comment>Диапазон таблицы</Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
        <ScriptVariable>
            <Name>in_hexBackgroundColor</Name>
            <Group />
            <Comment>Цвет фона ячейки</Comment>
            <DataTypeString>String</DataTypeString>
            <Direction>IN</Direction>
        </ScriptVariable>
    </Arguments>
