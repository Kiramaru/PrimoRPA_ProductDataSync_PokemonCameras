                                        <Name>QueryText</Name>
                                        <Value xsi:type="xsd:string">SELECT 
    p.name,
    p.abilities,
    p.types,
    c.title,
    c.rating,
    c.product_link
FROM pokemoninformation p
JOIN "camera&amp;pokemon" cp ON cp.id_pokemon = p.id
JOIN informationaboutcameras c ON c.id = cp.id_camera;</Value>
                                    </SerializationItem>
