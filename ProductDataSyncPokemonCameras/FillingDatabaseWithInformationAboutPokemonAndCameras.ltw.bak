                        <Components>
                            <SerializationComponent>
                                <ClassName>LTools.Database.Elements.WFExecuteQuery</ClassName>
                                <AssemblyName>LTools.Database, Version=1.0.1.1, Culture=neutral, PublicKeyToken=null</AssemblyName>
                                <Properties>
                                    <SerializationItem>
                                        <IsListValue>false</IsListValue>
                                        <Name>QueryText</Name>
                                        <Value xsi:type="xsd:string">DO $$
DECLARE
    pokemon_record RECORD;
    random_camera_id integer;
BEGIN
    FOR pokemon_record IN SELECT id FROM pokemoninformation LOOP
        IF NOT EXISTS (SELECT 1 FROM "camera&amp;pokemon" WHERE id_pokemon = pokemon_record.id) THEN
            SELECT id INTO random_camera_id 
            FROM informationaboutcameras 
            ORDER BY random() 
            LIMIT 1;
            
            INSERT INTO "camera&amp;pokemon" (id_pokemon, id_camera) 
            VALUES (pokemon_record.id, random_camera_id);
        END IF;
    END LOOP;
END $$;</Value>
                                    </SerializationItem>
